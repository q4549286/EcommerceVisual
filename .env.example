# ---- 数据库连接（必填） ----
# 例如 postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ---- 图像生成接口（应用启动后也可在管理后台 -> 系统设置中配置） ----
# OpenAI 兼容的 /v1 接口根地址
IMAGE_API_BASE=
# 图像生成 API Key
IMAGE_API_KEY=
# 模型名称，例如 gpt-image-1 / gpt-image-2 / dall-e-3 等
IMAGE_MODEL=

# ---- 仅 docker-compose 使用，用于初始化内置 PostgreSQL 容器 ----
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
